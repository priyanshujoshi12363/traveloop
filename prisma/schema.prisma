// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String   @unique
  password      String
  phoneNumber   String?
  city          String?
  country       String?
  bio           String?
  profilePic    String?
  language      String?  @default("en")
  createdAt     DateTime @default(now())
  updatedAt     DateTime?

  trips         Trip[]
  memberOf      TripMember[]
  notes         TripNote[]
  packingItems  PackingItem[]
  communityPosts CommunityPost[]
  communityComments CommunityComment[]
  communityLikes CommunityLike[]
}

model Trip {
  id            Int      @id @default(autoincrement())
  title         String
  destination   String
  startDate     DateTime
  endDate       DateTime
  budget        Float
  description   String?
  coverImage    String?
  status        String   @default("planned")
  isPublic      Boolean  @default(false)
  shareUrl      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  
  members       TripMember[]
  stops         TripStop[]
  notes         TripNote[]
  activities    TripActivity[]
  budgetItems   BudgetItem[]
  packingItems  PackingItem[]
}

model TripMember {
  id        Int      @id @default(autoincrement())
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  
  @@unique([tripId, userId])
}

model TripStop {
  id            Int      @id @default(autoincrement())
  tripId        Int
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  cityName      String
  country       String?
  startDate     DateTime
  endDate       DateTime
  orderIndex    Int
  costIndex     String?
  popularity    Int?
  stopNotes     String?
  createdAt     DateTime @default(now())
  
  activities    TripActivity[]
  tripNotes     TripNote[]
}

model TripActivity {
  id            Int      @id @default(autoincrement())
  tripId        Int
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stopId        Int?
  stop          TripStop? @relation(fields: [stopId], references: [id], onDelete: SetNull)
  name          String
  description   String?
  image         String?
  activityType  String
  cost          Float?
  duration      String?
  location      String?
  time          String?
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TripNote {
  id            Int      @id @default(autoincrement())
  tripId        Int
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  stopId        Int?
  stop          TripStop? @relation(fields: [stopId], references: [id], onDelete: SetNull)
  title         String?
  content       String
  isPrivate     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BudgetItem {
  id            Int      @id @default(autoincrement())
  tripId        Int
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  budgetCategory String
  itemName      String
  cost          Float
  date          DateTime?
  isPaid        Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
}

model PackingItem {
  id            Int      @id @default(autoincrement())
  tripId        Int
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  name          String
  packingCategory String
  isPacked      Boolean  @default(false)
  quantity      Int      @default(1)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tripId, userId, name])
}

model CityExploration {
  id            Int      @id @default(autoincrement())
  name          String
  country       String
  description   String?
  image         String?
  costIndex     String?
  popularity    Int?
  timeZone      String?
  attractions   String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([name, country])
}

model CommunityPost {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  title         String
  content       String
  image         String?
  category      String
  likes         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  comments      CommunityComment[]
  likedBy       CommunityLike[]
}

model CommunityComment {
  id            Int      @id @default(autoincrement())
  postId        Int
  post          CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommunityLike {
  id            Int      @id @default(autoincrement())
  postId        Int
  post          CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@unique([postId, userId])
}