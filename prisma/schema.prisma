generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {

  id Int @id @default(autoincrement())

  firstName String
  lastName  String

  email String @unique

  password String

  phoneNumber String?

  city    String?
  country String?

  bio String?

  profilePic String?

  createdAt DateTime @default(now())
  updatedAt    DateTime?
}